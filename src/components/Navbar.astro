---
import navs from '../data/nav-items.json';
---

<nav class="h-13 top-0 max-w-6xl mx-auto sm:px-4">
    <div class="bg-gray-100 text-black flex items-center px-2 sm:px-3 w-full h-full rounded-b-lg">
        <a href="/" class="font-bold h-9 flex rounded px-2 items-center transition duration-200 hover:bg-gray-300 active:bg-gray-300">
            <i class="bi-house-door text-2xl mr-1"></i>
            Home
        </a>

        <div class="grow flex justify-end">
            {navs.map(nav => (
                <a href={nav.url} class="font-bold h-9 flex rounded px-2 items-center transition duration-200 hover:bg-gray-300 active:bg-gray-300">
                    {nav.name}
                    
                    {!nav.url.startsWith("/") && (
                        <i class="ml-1.5 bi-box-arrow-up-right"></i>
                    )}
                </a>
            ))}
        </div>
    </div>
</nav>